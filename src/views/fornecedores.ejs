<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Fornecedores</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    button { padding: 5px 10px; cursor: pointer; }
    .btn-excluir { background-color: red; color: white; border: none; }
    .btn-editar { background-color: blue; color: white; border: none; }
  </style>
</head>
<body>
  <h1 style="text-align:center;">Cadastro de Fornecedores</h1>

  <form action="/fornecedores/add" method="POST" style="text-align:center;">
    <input type="text" name="nome" placeholder="Nome" required>
    <input type="text" name="telefone" placeholder="Telefone" required>
    <input type="email" name="email" placeholder="Email" required>
    <input type="text" name="produto" placeholder="Produto" required>
    <button type="submit">Adicionar</button>
  </form>

  <table>
    <tr>
      <th>ID</th><th>Nome</th><th>Telefone</th><th>Email</th><th>Produto</th><th>Excluir</th><th>Editar</th>
    </tr>
    <% fornecedores.forEach(f => { %>
      <tr>
        <td><%= f.id %></td>
        <td><%= f.nome %></td>
        <td><%= f.telefone %></td>
        <td><%= f.email %></td>
        <td><%= f.produto %></td>
        <td>
          <form action="/fornecedores/delete/<%= f.id %>" method="POST" style="display:contents;">
            <button type="submit" class="btn-excluir">Excluir</button>
          </form>
        </td>
        <td>
          <a href="/fornecedores/edit/<%= f.id %>">
            <button type="button" class="btn-editar">Editar</button>
          </a>
        </td>
      </tr>
    <% }) %>
  </table>

  <% if (typeof fornecedor !== 'undefined') { %>
    <h2 style="text-align:center;">Editar Fornecedor</h2>
    <form action="/fornecedores/edit/<%= fornecedor.id %>" method="POST" style="text-align:center;">
      <label>Nome:</label>
      <input type="text" name="nome" value="<%= fornecedor.nome %>" required>

      <label>Telefone:</label>
      <input type="text" name="telefone" value="<%= fornecedor.telefone %>" required>

      <label>Email:</label>
      <input type="text" name="email" value="<%= fornecedor.email %>" required>

      <label>Produto:</label>
      <input type="text" name="produto" value="<%= fornecedor.produto %>" required>

      <button type="submit">Salvar</button>
    </form>
  <% } %>
</body>
</html>